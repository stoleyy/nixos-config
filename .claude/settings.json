{
  "permissions": {
    "deny": [
      "Read(/home/stoleyy/.ssh/**)",
      "Read(/home/stoleyy/.config/sops/**)",
      "Read(/home/stoleyy/.gnupg/**)",
      "Read(**/.env*)",
      "Write(/home/stoleyy/.ssh/**)",
      "Write(/home/stoleyy/.config/sops/**)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf /*)"
    ],
    "allow": [
      "Bash(nix flake check:*)",
      "Bash(nix flake metadata:*)",
      "Bash(nix flake show:*)",
      "Bash(nix flake lock:*)",
      "Bash(nix eval .#nixosConfigurations.predator.config.system.build.toplevel.drvPath:*)",
      "Bash(nix eval .#nixosConfigurations.predator.config.*:*)",
      "Bash(nixos-rebuild build --flake .#predator:*)",
      "Bash(nixos-rebuild dry-build --flake .#predator:*)",
      "Bash(nixfmt:*)",
      "Bash(statix check:*)",
      "Bash(statix fix:*)",
      "Bash(deadnix:*)",
      "Bash(gitleaks detect:*)",
      "Bash(shellcheck:*)",
      "Bash(vulnix:*)",
      "Bash(nvd diff:*)",
      "Bash(nix-tree:*)",
      "Bash(nix path-info:*)",
      "Bash(nix develop:*)",
      "Bash(nix build:*)",
      "Bash(nix run:*)",
      "Bash(nix log:*)",
      "Bash(systemctl status:*)",
      "Bash(systemctl --failed:*)",
      "Bash(systemctl list-units:*)",
      "Bash(journalctl:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git remote:*)",
      "Bash(nh:*)",
      "Bash(sops:*)",
      "Bash(nix-collect-garbage:*)",
      "Bash(jq:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/bootstrap-nix.sh", "timeout": 360, "statusMessage": "Bootstrapping Nix…" },
          { "type": "command", "command": ".claude/hooks/session-start.sh", "timeout": 30 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/secret-scanner.sh", "timeout": 5, "statusMessage": "Scanning for secrets…" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/dangerous-command-guard.sh", "timeout": 5, "statusMessage": "Safety check" },
          { "type": "command", "command": ".claude/hooks/rebuild-gate.sh", "timeout": 5 },
          { "type": "command", "command": ".claude/hooks/commit-secret-scanner.sh", "timeout": 10, "statusMessage": "Scanning commit…" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/gateguard-nix.sh", "timeout": 5, "statusMessage": "GateGuard" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/post-edit-nixfmt.sh", "timeout": 10, "statusMessage": "nixfmt" }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/pre-compact-save.sh", "timeout": 10, "statusMessage": "Saving session state…" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/anti-rationalization.sh", "timeout": 5 },
          { "type": "command", "command": ".claude/hooks/desktop-notify.sh", "timeout": 5 }
        ]
      }
    ]
  }
}
