_:

{
  programs.ghostty = {
    enable = true;
    settings = {
      background = "#000000";
      foreground = "#e5e5e5";
      cursor-color = "#ffffff";
      background-opacity = 1.0;
      background-blur-radius = 0;
      font-family = "GeistMono Nerd Font";
      font-size = 12;
      window-padding-x = 14;
      window-padding-y = 14;
      window-decoration = false;
      cursor-style = "block";
      cursor-style-blink = false;
      mouse-hide-while-typing = true;
    };
  };
}
